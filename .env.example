# Copy this file to .env and fill in real values.

# MongoDB connection string used by apps/api (via Mongoose)
MONGODB_URI=mongodb://localhost:27017/nutrisync

# Comma-separated list of origins allowed to make CORS requests to apps/api.
# Default below is apps/web's Vite dev server. Add prod origins per environment.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Secret used to sign/verify auth JWTs (HS256). apps/api refuses to boot
# without this set. Generate one with: openssl rand -base64 48
JWT_SECRET=

# Port apps/api listens on. Optional locally (defaults to 4000). Cloud hosts
# (Render, etc.) inject this themselves - don't hardcode it there.
PORT=4000

# Set to "production" in deployed environments. Hides internal error details
# from API responses and makes the auth cookie require HTTPS (`secure`).
# Leave unset locally.
NODE_ENV=production
